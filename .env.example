# Conexion al Postgres de AUTRAB (el MISMO que usa n8n). NO subir el .env real al repo.
# Si Postgres esta en el MISMO proyecto de easypanel, usa el host interno (nombre del servicio).
DATABASE_URL=postgres://USUARIO:PASSWORD@HOST:5432/NOMBRE_DB

# Scheduling
RUN_LOOP=1        # 1 = demonio que corre y duerme cada INTERVAL_DAYS. 0 = corre una vez y termina (para cron externo).
INTERVAL_DAYS=7   # cada cuantos dias corre (si RUN_LOOP=1)

# Opcionales
REFRESH_DIAS=30   # re-scrapea modelos cuya data sea mas vieja que N dias
MAX_PAGES=10      # paginas por modelo (24 listings/pagina)
